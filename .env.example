# Nomor WhatsApp tujuan checkout (format internasional tanpa +, contoh: 6281234567890)
NEXT_PUBLIC_WHATSAPP_NUMBER=6281234567890

# Password untuk login admin (/admin/login)
ADMIN_PASSWORD=ganti_password_admin

# Rahasia untuk sign cookie sesi admin (isi string panjang acak)
ADMIN_SESSION_SECRET=ganti_rahasia_session_yang_panjang_dan_acak

# Neon / PostgreSQL connection string
# Contoh aman:
# postgres://username:password@host.neon.tech/dbname?sslmode=verify-full
DATABASE_URL=postgres://username:password@host.neon.tech/dbname?sslmode=verify-full
